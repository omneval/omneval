{
  "name": "@lantern/sdk",
  "version": "0.1.0",
  "description": "Browser-compatible OpenTelemetry tracer and prompt client for Lantern",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/node/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/node/index.ts --format esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@opentelemetry/sdk-node": "^0.200.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.200.0",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.1"
  },
  "peerDependencies": {
    "@opentelemetry/sdk-node": ">=0.200.0",
    "@opentelemetry/exporter-trace-otlp-http": ">=0.200.0"
  }
}
