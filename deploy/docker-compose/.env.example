# Lantern docker-compose environment variables
#
# Copy this file to .env and override values as needed:
#   cp .env.example .env
#
# Changes take effect after rebuilding:
#   docker compose up --build

# --- PostgreSQL ---
# These values must match LANTERN_DATABASE_DSN in the service config.
POSTGRES_USER=lantern
POSTGRES_PASSWORD=lantern
POSTGRES_DB=lantern

# --- MinIO ---
# These values must match LANTERN_STORAGE_ACCESS_KEY / LANTERN_STORAGE_SECRET_KEY.
MINIO_ROOT_USER=minio_s3_access_key
MINIO_ROOT_PASSWORD=minio_s3_secret_key
