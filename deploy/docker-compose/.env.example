# Lantern docker-compose environment variables
#
# Copy this file to .env and override values as needed:
#   cp .env.example .env

# --- MinIO ---
MINIO_ROOT_USER=minio_s3_access_key
MINIO_ROOT_PASSWORD=minio_s3_secret_key

# --- PostgreSQL ---
POSTGRES_USER=lantern
POSTGRES_PASSWORD=lantern
POSTGRES_DB=lantern
