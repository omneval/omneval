# omneval docker-compose environment variables
#
# Copy this file to .env and override values as needed:
#   cp .env.example .env
#
# Changes take effect after rebuilding:
#   docker compose up --build

# --- PostgreSQL ---
# These values must match omneval_DATABASE_DSN in the service config.
POSTGRES_USER=omneval
POSTGRES_PASSWORD=omneval
POSTGRES_DB=omneval

# --- MinIO ---
# These values must match omneval_STORAGE_ACCESS_KEY / omneval_STORAGE_SECRET_KEY.
MINIO_ROOT_USER=minio_s3_access_key
MINIO_ROOT_PASSWORD=minio_s3_secret_key
