# GitHub personal access token — required for gh CLI inside sandboxes
GH_TOKEN=

# Discord incoming webhook URL — optional, enables per-issue notifications
# Leave blank to disable Discord notifications
DISCORD_WEBHOOK_URL=

# Langfuse tracing — optional, enables per-issue LLM call tracing
# When set, a local HTTP proxy intercepts all Pi agent LLM calls and records
# them in Langfuse. Each GitHub issue becomes a session; each phase
# (planner / implementer / reviewer / merger) becomes a trace within it.
#
# Get your keys from https://cloud.langfuse.com (cloud) or your self-hosted instance.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse server URL — defaults to Langfuse Cloud; set to your self-hosted URL if needed
# LANGFUSE_HOST=https://cloud.langfuse.com

# Port the local LLM proxy listens on (host-side). Must not conflict with
# llama-server (default 8080). Docker containers reach it via host.docker.internal.
# LANGFUSE_PROXY_PORT=8081

# Override the llama-server URL the proxy forwards to (host-side address).
# LLAMA_SERVER_URL=http://localhost:8080

OTEL_EXPORTER_OTLP_ENDPOINT="https://us.cloud.langfuse.com/api/public/otel"
# AUTH_STRING = base64("pk-lf-...:sk-lf-...") — paste the literal encoded value here; variable interpolation is not supported
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic <base64-encoded-pk:sk>,x-langfuse-ingestion-version=4"
